ANTHROPIC_API_KEY=sk-ant-your-key-here

# Fast pass (runs first, ~$0.002/extract)
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# Strong pass (auto retry when Haiku looks weak, ~$0.006/extract)
ANTHROPIC_MODEL_STRONG=claude-sonnet-4-6

# Retry with Sonnet when Haiku returns empty rows, low confidence, or bad dimensions
ENABLE_SONNET_FALLBACK=true

# Cache system prompt + tool schema (saves ~90% on repeated extracts)
ENABLE_PROMPT_CACHE=true

# DPI: strong pass re-renders PDF at higher resolution
PDF_DPI_FAST=200
PDF_DPI_STRONG=250

# Optional: extra CORS origins (comma-separated). Localhost is allowed by default.
# CORS_ORIGINS=http://localhost:3002

# --- Guardrails (protect Anthropic spend on public demo) ---
MAX_PDF_BYTES=26214400
MAX_PDF_PAGES=50
PDF_OPS_PER_IP_MINUTE=30
EXTRACT_PER_IP_HOUR=5
EXTRACT_PER_IP_DAY=15
EXTRACT_GLOBAL_DAILY=50

# Optional: require X-Demo-Token header (set same value as NEXT_PUBLIC_DEMO_ACCESS_TOKEN in frontend/.env.local)
# DEMO_ACCESS_TOKEN=your-random-secret-here
